generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id                 String   @id @default(cuid())
  title              String
  sku                String   @unique
  brand              String?
  category           String?
  description        String?
  costPrice          Decimal
  sellingPrice       Decimal
  marginPercent      Decimal
  quantity           Int
  reorderLevel       Int      @default(5)
  imageUrl           String?
  isMachine          Boolean  @default(false)
  defaultRentDeposit Decimal?
  defaultDailyRent   Decimal?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  inventoryLogs InventoryLog[]
  rentals       Rental[]
  saleLines     SaleLine[]

  @@index([brand])
  @@index([category])
  @@index([quantity])
  @@index([createdAt])
  @@index([isMachine])
}

model AppSetting {
  id             String   @id @default("app")
  showCostPrice  Boolean  @default(true)
  showMargin     Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Sale {
  id          String     @id @default(cuid())
  saleDate    DateTime   @default(now())
  customer    String?
  paymentMode String     @default("CASH")
  subtotal    Decimal
  totalCost   Decimal
  grossProfit Decimal
  note        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  lines SaleLine[]

  @@index([saleDate])
  @@index([paymentMode])
  @@index([createdAt])
}

model SaleLine {
  id           String   @id @default(cuid())
  saleId       String
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productTitle String
  productSku   String
  quantity     Int
  unitPrice    Decimal
  unitCost     Decimal
  lineTotal    Decimal
  lineProfit   Decimal
  createdAt    DateTime @default(now())

  @@index([saleId])
  @@index([productId])
  @@index([createdAt])
}

model InventoryLog {
  id        String   @id @default(cuid())
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  type      String
  quantity  Int?
  note      String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

model Rental {
  id             String   @id @default(cuid())
  productId      String?
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  machineTitle   String
  machineSku     String
  customerName   String?
  customerPhone  String?
  deposit        Decimal
  dailyRent      Decimal
  paymentMode    String   @default("CASH")
  startedAt      DateTime @default(now())
  closedAt       DateTime?
  calendarDays   Int?
  rentTotal      Decimal?
  depositBalance Decimal?
  status         String   @default("OPEN")
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([productId])
  @@index([status])
  @@index([startedAt])
  @@index([closedAt])
}
